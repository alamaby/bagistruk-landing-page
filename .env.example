# Public anon key — safe to ship in the client. The Edge Functions this
# landing page calls rate-limit by IP hash and validate every action via
# a one-time token, so an exposed anon key cannot be abused to subscribe
# other people or delete accounts at scale.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-PUBLIC-ANON-KEY
